modules = ["nodejs-20", "web", "bash", "postgresql-16", "go-1.25"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Redis"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend Worker"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Driver App"

[[workflows.workflow]]
name = "Redis"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "redis-server --port 6379 --save '' --appendonly no"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Backend Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && go run ./cmd/server"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Backend Worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && go run ./cmd/worker"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Driver App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/driver && PORT=5174 BASE_PATH=/ pnpm dev"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
APP_ENV = "development"
JWT_ISSUER = "avex"
REDIS_URL = "redis://127.0.0.1:6379/0"
JWT_SECRET = "44eaa6900b18640ecc365a3b5175019ad5f29e631ec4003b8ca9f403d06667002277f6a449ccd2713e11916bbf17e825"
MAPBOX_ACCESS_TOKEN = "MAPBOX_PUBLIC_TOKEN_PLACEHOLDER"

[nix]
packages = ["run"]
channel = "stable-25_05"
