modules = ["nodejs-20", "web", "bash", "postgresql-16", "go-1.25"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Redis"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend Worker"

[[workflows.workflow]]
name = "Redis"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "redis-server --port 6379 --save '' --appendonly no"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Backend Worker"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && go run ./cmd/worker"

[workflows.workflow.metadata]
outputType = "console"

[workflow.Project]
steps = ["server", "worker", "driver"]

[workflow.server]
type = "shell"
command = """
export DATABASE_URL="postgres://avex:avex@localhost:5432/avex_dev?sslmode=disable"
export REDIS_URL="redis://localhost:6379/0"
export JWT_SECRET="avex-secret-key-change-in-production-32chars"
export JWT_ISSUER="avex"
export MAPBOX_ACCESS_TOKEN="MAPBOX_PUBLIC_TOKEN_PLACEHOLDER"
cd backend
docker compose up -d postgres redis 2>/dev/null || true
sleep 5
go run ./cmd/server
"""
blockProgress = true

[workflow.worker]
type = "shell"
command = """
export DATABASE_URL="postgres://avex:avex@localhost:5432/avex_dev?sslmode=disable"
export REDIS_URL="redis://localhost:6379/0"
cd backend
sleep 8
go run ./cmd/worker
"""
blockProgress = true

[workflow.driver]
type = "shell"
command = """
export PORT=5174
export BASE_PATH=/
cd artifacts/driver
sleep 10
pnpm dev
"""
blockProgress = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
APP_ENV = "development"
JWT_ISSUER = "avex"
REDIS_URL = "redis://127.0.0.1:6379/0"
JWT_SECRET = "44eaa6900b18640ecc365a3b5175019ad5f29e631ec4003b8ca9f403d06667002277f6a449ccd2713e11916bbf17e825"

[nix]
packages = ["run"]
channel = "stable-25_05"
