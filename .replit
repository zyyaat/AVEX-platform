modules = ["nodejs-24", "go-1.25", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[workflow.Project]
steps = ["server", "worker", "driver"]

[workflow.server]
type = "shell"
command = """
export DATABASE_URL="postgres://avex:avex@localhost:5432/avex_dev?sslmode=disable"
export REDIS_URL="redis://localhost:6379/0"
export JWT_SECRET="avex-secret-key-change-in-production-32chars"
export JWT_ISSUER="avex"
export MAPBOX_ACCESS_TOKEN="MAPBOX_PUBLIC_TOKEN_PLACEHOLDER"
cd backend
docker compose up -d postgres redis 2>/dev/null || true
sleep 5
go run ./cmd/server
"""
blockProgress = true

[workflow.worker]
type = "shell"
command = """
export DATABASE_URL="postgres://avex:avex@localhost:5432/avex_dev?sslmode=disable"
export REDIS_URL="redis://localhost:6379/0"
cd backend
sleep 8
go run ./cmd/worker
"""
blockProgress = true

[workflow.driver]
type = "shell"
command = """
export PORT=5174
export BASE_PATH=/
cd artifacts/driver
sleep 10
pnpm dev
"""
blockProgress = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]

[nix]
packages = ["run"]
