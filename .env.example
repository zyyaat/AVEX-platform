# ============================================================================
# AVEX Platform — Environment Variables (Replit example)
# ============================================================================
# On Replit: DO NOT use this file. Set these as Secrets via the lock icon
# in the left sidebar. Secrets set in the Replit UI override everything here.
#
# Locally: copy this file to .env and fill in real values.
#   cp .env.example .env
#   nano .env
#
# IMPORTANT: NEVER commit the .env file. It is gitignored.
# ============================================================================

# ----- App -----
APP_NAME=avex-backend
APP_ENV=development
APP_PORT=8080
APP_INSTANCE_ID=node-1
APP_LOG_LEVEL=info
APP_LOG_FORMAT=json

# ----- Database (PostgreSQL) -----
# On Replit: auto-populated by the postgresql-16 module.
# Locally: create the database first.
DATABASE_URL=postgres://avex:avex@127.0.0.1:5432/avex_dev?sslmode=disable
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=5

# ----- Redis -----
# On Replit: started by run.sh as a daemon.
# Locally: install redis and start it.
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_POOL_SIZE=20

# ----- JWT (SECRET — set via Replit Secrets) -----
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_ME_WITH_RANDOM_32_CHAR_HEX_STRING
JWT_ISSUER=avex
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=720h

# ----- Password Hashing -----
BCRYPT_COST=12

# ----- Mapbox (SECRET — set via Replit Secrets) -----
# Get a public token from: https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=REPLACE_ME_WITH_YOUR_MAPBOX_PUBLIC_TOKEN

# ----- OpenTelemetry -----
OTEL_EXPORTER=stdout
OTEL_SERVICE_NAME=avex-backend
OTEL_SAMPLER_RATIO=1.0

# ----- CORS -----
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept,X-Request-Id
CORS_ALLOW_CREDENTIALS=true

# ----- Secrets Provider -----
SECRETS_PROVIDER=env
